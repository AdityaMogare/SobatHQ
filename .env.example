# Server
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Redis (optional — falls back to in-memory if unset)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# Google OAuth (Gmail, Calendar, Drive, Sheets)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Slack OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_REDIRECT_URI=http://localhost:3001/api/auth/slack/callback

# Session / secrets
SESSION_SECRET=change-me-in-production-use-long-random-string
TOKEN_ENCRYPTION_KEY=

# Qwen (DashScope) — https://dashscope.aliyuncs.com
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_ENABLE_REASONING=true

# Frontend
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
